{
  "name": "undef-terminal-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint src/",
    "fix": "biome check --write --unsafe src/"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@vitest/coverage-v8": "4.1.2",
    "jsdom": "29.0.1",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  }
}
