FROM python:3.11-slim
RUN apt-get update -qq && apt-get install -y -qq libpam0g-dev gcc make libpam-runtime

# Install Python deps first (cache layer)
RUN pip install -q pamela pytest pytest-asyncio pytest-cov pytest-timeout

# Copy package source and install
WORKDIR /pkg
COPY . .
RUN pip install -q -e .

# Build native libraries
RUN make -C native/capture/ clean && make -C native/capture/ && \
    mkdir -p src/undef/terminal/pty/_native && \
    cp native/capture/libuterm_capture.so src/undef/terminal/pty/_native/ && \
    make -C native/pam_uterm/ clean && make -C native/pam_uterm/

# PAM service config and test user
RUN printf 'auth     required pam_unix.so\naccount  required pam_unix.so\nsession  required pam_unix.so\n' \
    > /etc/pam.d/undef-terminal && \
    # Prevent nsswitch from trying network lookups (LDAP/NIS) that aren't in a container
    printf 'passwd: files\ngroup: files\nshadow: files\nhosts: files dns\n' > /etc/nsswitch.conf && \
    useradd -m testuser && echo 'testuser:testpass123' | chpasswd

CMD ["pytest", "tests/", "-v", "--no-header", "-p", "no:randomly", "--timeout=10"]
