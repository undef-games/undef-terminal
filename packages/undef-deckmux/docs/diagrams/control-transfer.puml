@startuml control-transfer
title DeckMux — Control Transfer (Request / Handover)

skinparam backgroundColor #0d1117
skinparam defaultFontColor #c9d1d9
skinparam sequenceArrowColor #58a6ff
skinparam sequenceLifeLineBorderColor #30363d
skinparam sequenceParticipantBorderColor #30363d
skinparam sequenceParticipantBackgroundColor #161b22
skinparam noteBorderColor #30363d
skinparam noteBackgroundColor #161b22

participant "Jane\n(operator)" as J
participant "Server\n(TermHub)" as S
participant "Tim\n(DM/owner)" as T
participant "Others" as O

J -> J: clicks Tim's avatar\n-> "Request control"
J -> S: control_request {target: tim}
S -> T: control_request_notification\n{from: "Jane"}
note over T: Toast appears:\n"Jane requesting control"\n[Hand over] [Deny]

alt Tim accepts
  T -> S: control_handover {to: jane}
  S -> S: release Tim's lease\nacquire Jane's lease
  S -> J: control_transfer {to: jane, reason: "handover"}
  S -> T: control_transfer {to: jane, reason: "handover"}
  S -> O: control_transfer {to: jane, reason: "handover"}
  note over J: Pulsing border activates\nJane in status bar
  note over T: Border deactivates\nNo longer DM
else Tim denies
  T -> S: control_deny {requester: jane}
  S -> J: control_denied {}
  note over J: Toast: "Request denied"
end

@enduml
