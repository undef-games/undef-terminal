@startuml presence-join
title DeckMux — Browser Joins Session

skinparam backgroundColor #ffffff
skinparam defaultFontColor #333333
skinparam sequenceArrowColor #2563eb
skinparam sequenceLifeLineBorderColor #d1d5db
skinparam sequenceParticipantBorderColor #d1d5db
skinparam sequenceParticipantBackgroundColor #f3f4f6
skinparam noteBorderColor #d1d5db
skinparam noteBackgroundColor #f9fafb

participant "Browser A\n(existing)" as A
participant "Server\n(TermHub)" as S
participant "Browser B\n(joining)" as B

B -> S: WebSocket connect
S -> B: hello {presence_enabled: true}
S -> B: presence_sync {users: [A], config: {...}}
B -> S: presence_update {scroll_line: 0, name: "Red Hawk"}
S -> A: presence_update {user_id: B, name: "Red Hawk", color: "#2ecc71"}
note over A: Avatar bar adds "Red Hawk"\nGreen edge bar appears

@enduml
