# undef-terminal — FastAPI reference server
#
# Build (from repo root):
#   docker build -f docker/Dockerfile.server -t undef-terminal-server .
#
# Run (dev mode, no pre-configured sessions):
#   docker run --rm -p 8780:8780 undef-terminal-server
#
# Run with a custom config:
#   docker run --rm -p 8780:8780 \
#     -v /path/to/my.toml:/config/server.toml:ro \
#     undef-terminal-server
#
# The server binds on 0.0.0.0:8780 inside the container.
# Dashboard: http://localhost:8780/app/
# Health:    http://localhost:8780/api/health
# Sessions:  http://localhost:8780/api/sessions
#

FROM python:3.11-slim

# Keeps Python from buffering stdout/stderr
ENV PYTHONUNBUFFERED=1

RUN pip install --no-cache-dir uv

WORKDIR /app

# Copy package source and metadata
COPY pyproject.toml README.md ./
COPY src/ src/

# Install the server extras (FastAPI, uvicorn, pyjwt)
RUN uv pip install --system ".[server]"

# Default dev config: no sessions, no JWT, open access.
# Override via: -v /path/to/config.toml:/config/server.toml:ro
COPY docker/server.toml /config/server.toml

EXPOSE 8780

CMD ["uterm-server", "--config", "/config/server.toml", "--host", "0.0.0.0", "--port", "8780"]
