@startuml system-overview
title undef-terminal — 12-Package System Overview

skinparam backgroundColor #ffffff
skinparam defaultFontColor #333333
skinparam componentBorderColor #d1d5db
skinparam componentBackgroundColor #f3f4f6
skinparam packageBorderColor #d1d5db
skinparam packageBackgroundColor #ffffff
skinparam arrowColor #2563eb
skinparam noteBorderColor #d1d5db
skinparam noteBackgroundColor #f9fafb

skinparam rectangle {
  BorderColor #2563eb
  BackgroundColor #eff6ff
  FontColor #1e40af
}

' --- Zero-dep leaf packages ---
rectangle "undef-terminal-render\n(ANSI palette, SGR, image)" as RENDER
rectangle "undef-terminal-shell\n(Python REPL, ushell)" as SHELL
rectangle "undef-terminal-deckmux\n(collaborative presence)" as DECKMUX
rectangle "undef-terminal-detection\n(prompt detection)" as DETECT
rectangle "undef-terminal-transports\n(Telnet / SSH / WS)" as XPORT
rectangle "undef-terminal-gateway\n(protocol conversion)" as GW
rectangle "undef-terminal-pty\n(PTY, PAM, capture)" as PTY
rectangle "undef-terminal-tunnel\n(tunnel protocol, HTTP inspect)" as TUNNEL
rectangle "undef-terminal-manager\n(agent swarm)" as MGR

' --- Core ---
package "undef-terminal (core)" as CORE {
  [bridge hub\nserver / CLI\nclient / MCP] as CORE_C
}

' --- Edge packages ---
package "undef-terminal-cloudflare" as CF {
  [CF Worker adapter\nDurable Objects / KV] as CF_C
}

package "undef-terminal-frontend" as FE {
  [Browser UI\n(vanilla TypeScript)] as FE_C
}

package "undef-telemetry" as TELEM {
  [structured logging\n& trace context] as TELEM_C
}

' --- Core required deps ---
RENDER <-- CORE_C : required
SHELL <-- CORE_C : required
TELEM_C <-- CORE_C : required

' --- Core optional integration (mixin / extras) ---
DECKMUX <.. CORE_C : [terminal] mixin
DETECT <.. CORE_C : symlink
XPORT <.. CORE_C : [ssh/ws] extras
GW <.. CORE_C : symlink
PTY <.. CORE_C : [terminal] extra
TUNNEL <.. CORE_C : symlink
MGR <.. CORE_C : symlink

' --- Leaf optional deps ---
SHELL ..> RENDER : [images] extra
GW ..> XPORT : uses transports

' --- CF adapter ---
CORE_C <-- CF_C : adapter

' --- Frontend connects via WS ---
FE_C --> CORE_C : WebSocket / REST
FE_C --> CF_C : WebSocket / REST

note bottom of RENDER : zero deps
note bottom of SHELL : zero deps
note bottom of DECKMUX : zero deps
note bottom of DETECT : zero deps

@enduml
